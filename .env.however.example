# ------------------------------
# HoweverPromptfoo local profile
# Copy to .env.however.local
# ------------------------------

# Core model providers
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Local/private model gateways
OLLAMA_BASE_URL=http://127.0.0.1:11434
HOWEVER_OLLAMA_BASE_URL=
OLLAMA_API_KEY=
HOWEVER_OPENAI_BASE_URL=http://127.0.0.1:4000/v1

# Storage backends (optional)
HOWEVER_DB_URL=file:./var/howeverpromptfoo.sqlite
HOWEVER_REDIS_URL=redis://127.0.0.1:6379/0

# Trace and observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Promptfoo runtime
PROMPTFOO_CACHE_ENABLED=true
PROMPTFOO_DISABLE_TELEMETRY=true
